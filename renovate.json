{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "schedule:monthly", ":automergeMinor", ":maintainLockFilesMonthly"],
  "ignorePresets": ["group:recommended", "group:monorepos"],
  "groupName": "all",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "manage node upgrades manually",
      "matchPackageNames": ["node", "actions/node-versions"],
      "enabled": false
    },
    {
      "description": "manage ruby upgrades manually",
      "matchPackageNames": ["ruby"],
      "enabled": false
    }
  ]
}
