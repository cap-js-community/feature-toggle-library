{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:monthly",
    ":automergeMinor",
    ":maintainLockFilesMonthly",
    "helpers:pinGitHubActionDigests"
  ],
  "ignorePresets": ["group:recommended", "group:monorepos"],
  "platformAutomerge": true,
  "groupName": "all",
  "minimumReleaseAge": "7 days",
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "manage node upgrades manually",
      "matchDepNames": ["node"],
      "enabled": false
    },
    {
      "description": "manage ruby upgrades manually",
      "matchDepNames": ["ruby"],
      "enabled": false
    }
  ]
}
